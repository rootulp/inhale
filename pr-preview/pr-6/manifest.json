{
  "manifest_version": 3,
  "name": "Inhale",
  "version": "0.1.0",
  "description": "A clean, focused new tab page with nature photos, clock, and daily inspiration.",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
